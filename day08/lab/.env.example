# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key

# === LLM Provider ===
# Chọn "gemini" (khuyến nghị) hoặc "openai"
LLM_PROVIDER=gemini

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=...

# Model mặc định
LLM_MODEL=gemini-1.5-flash
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (optional fallback)
# OPENAI_API_KEY=sk-...

# === Embedding ===
# Chọn "gemini" (khuyến nghị) hoặc "local" hoặc "index"
EMBEDDING_PROVIDER=gemini

# Gemini embedding model
EMBEDDING_MODEL=models/text-embedding-004

# Model sentence-transformers nếu dùng local embedding
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
